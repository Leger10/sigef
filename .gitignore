# Créer/éditer le .gitignore
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.pnpm-store/

# Build
dist/
dist-ssr/
build/

# Environment variables
.env
.env.local
.env.*.local
.env.production

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
desktop.ini

# Netlify
.netlify/

# Temporary files
*.tmp
*.temp
EOF